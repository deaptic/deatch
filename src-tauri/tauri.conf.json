{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deatch",
  "version": "0.1.20",
  "identifier": "com.deaptic.deatch",
  "build": {
    "beforeDevCommand": "deno task dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Deatch",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 500,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; media-src 'self'; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/deaptic/deatch/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGMkVDQzhFOTQzRjZEM0QKUldROWJUK1Vqc3d1WDBUUUZwOHVvbUNOc2thaDRraFgzbkZWVlB0KzV2ZnhQUnZObCtLcUNrc2cK"
    }
  }
}
